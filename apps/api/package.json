{
  "name": "@saas-pricing/api",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript business API scaffold for the SaaS pricing platform.",
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "start": "tsx src/server.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "test:live-db": "RUN_LIVE_DATABASE_SMOKE=1 node --import tsx --test test/database-live-smoke.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@saas-pricing/job-contracts": "0.1.0",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.6.1",
    "jose": "^6.1.0",
    "pg": "^8.20.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "pg-mem": "^3.0.14"
  }
}
