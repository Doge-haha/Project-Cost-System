{
  "name": "saas-pricing-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "packages/job-contracts",
    "apps/frontend",
    "apps/api",
    "apps/mcp-gateway",
    "apps/worker"
  ],
  "scripts": {
    "dev:deps:up": "docker compose -f deploy/docker/docker-compose.dev.yml up -d --wait",
    "dev:deps:down": "docker compose -f deploy/docker/docker-compose.dev.yml down",
    "docs:api": "npm run docs:api-routes && npm run docs:openapi-current",
    "docs:api-routes": "node scripts/generate-implemented-routes-doc.mjs",
    "docs:openapi-current": "node scripts/generate-openapi-v1-current.mjs",
    "docs:openspec": "npx --yes @fission-ai/openspec validate doc-normalize-v1-to-openspec",
    "api:test:live-db": "DATABASE_URL=postgres://postgres:postgres@localhost:5432/saas_pricing npm --workspace @saas-pricing/api run test:live-db",
    "dev:smoke:live-db": "npm run dev:deps:up && npm run api:test:live-db",
    "test": "npm run test:packages && npm run test:workspace && npm run test:ai-runtime",
    "test:packages": "npm run test --workspaces --if-present",
    "test:workspace": "node --test tests/*.test.mjs",
    "test:ai-runtime": "pytest apps/ai-runtime/tests",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
